RewriteEngine On
DirectoryIndex index.html

# Site cutover: ora/site/ (Zensical) now serves at root /
# Old site content remains accessible at /v/
# ora/ remains accessible for preview and source.

# 1. Bare root serves new site immediately
RewriteRule ^$ ora/site/index.html [L]

# Handle any direct requests for the old legacy index.php (or index.html)
RewriteRule ^index\.(php|html)$ / [R=301,L]

# 2. Pass-through preserved paths (/v/ old site, /ora/ preview)
RewriteCond %{REQUEST_URI} ^/(v|ora)(/|$)
RewriteRule ^ - [L,NC]

# 3. If file or directory exists at root (favicons, robots.txt, flashcards, etc.), serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4. For directory-style requests (no trailing slash) that map to a dir in the new site,
#    redirect to public path with trailing slash (avoids leaking ora/site/ in URLs)
RewriteCond %{REQUEST_URI} !\.[a-z0-9]+$
RewriteCond %{REQUEST_URI} !/$
RewriteCond %{DOCUMENT_ROOT}/ora/site%{REQUEST_URI}/ -d
RewriteRule ^(.*)$ /$1/ [R=301,L]

# 5. Map everything else into the built Zensical site
RewriteRule ^(.*)$ ora/site/$1 [L]

# Wire the static 404 page
ErrorDocument 404 /ora/site/404.html
