        { "passage_segment_id": "1a", "text": "Χαῖρε Μαρία,", "phonetic": "Ché-re Ma-rí-a," },
        { "passage_segment_id": "1b", "text": "κεχαριτωμένη,", "phonetic": "ke-cha-ri-to-mé-ni," },
        { "passage_segment_id": "1c", "text": "ὁ Κύριος μετὰ σοῦ·", "phonetic": "o Ký-ri-os me-tá soú·" }
      ]
    },
    {
      "passage_id": 2,
      "segments": [
        { "passage_segment_id": "2a", "text": "εὐλογημένη σὺ ἐν γυναιξί,", "phonetic": "eu-lo-gē-mé-nē sỳ en gy-nai-xí," },
        { "passage_segment_id": "2b", "text": "καὶ εὐλογημένος ὁ καρπὸς τῆς κοιλίας σου", "phonetic": "kai eu-lo-gē-mé-nos ho kar-pòs tēs koi-lí-as sou" },
