      ]
    },
    {
      "passage_id": 3,
      "segments": [
        { "passage_segment_id": "3a", "text": "Ἁγία Μαρία, Θεοτόκε,", "phonetic": "Ha-gí-a Ma-rí-a, The-o-tó-ke," },
        { "passage_segment_id": "3b", "text": "πρέσβευε ὑπὲρ ἡμῶν", "phonetic": "prés-beu-e hy-pèr hē-mṓn" },
        { "passage_segment_id": "3c", "text": "τῶν ἁμαρτωλῶν,", "phonetic": "tōn ha-mar-tō-lṓn," }
      ]
    },
    {
      "passage_id": 4,
      "segments": [
