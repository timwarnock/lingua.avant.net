        { "passage_segment_id": "11e", "text": "肉体の復活、", "phonetic": "nikutai no fukkatsu," },
        { "passage_segment_id": "11f", "text": "永遠のいのちを信じます,", "phonetic": "eien no inochi o shinjimasu," }
