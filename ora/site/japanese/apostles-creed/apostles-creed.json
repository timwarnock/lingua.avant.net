    {
      "passage_id": 3,
      "segments": [
        { "passage_segment_id": "3a", "text": "主は聖霊によってやどり、", "phonetic": "Shu wa Seirei ni yotte yadori," }
      ]
    },
    {
      "passage_id": 4,
      "segments": [
        { "passage_segment_id": "4a", "text": "おとめマリアから生まれ、", "phonetic": "otome Maria kara umare," }
      ]
    },
    {
      "passage_id": 5,
      "segments": [
        { "passage_segment_id": "5a", "text": "ポンティオ・ピラトのもとで苦しみを受け、", "phonetic": "Pontio Pirato no moto de kurushimi o uke," },
        { "passage_segment_id": "5b", "text": "十字架につけられ、", "phonetic": "jūjika ni tsukerare," },
        { "passage_segment_id": "5c", "text": "死んで葬られ、", "phonetic": "shinde hōmurare," }
      ]
    },
    {
      "passage_id": 6,
      "segments": [
        { "passage_segment_id": "6a", "text": "陰府にくだり、", "phonetic": "infu ni kudari," }
      ]
    },
    {
      "passage_id": 7,
      "segments": [
        { "passage_segment_id": "7a", "text": "三日目に死者のうちから復活し、", "phonetic": "mikka me ni shisha no uchi kara fukkatsu shi," }
      ]
    },
    {
      "passage_id": 8,
      "segments": [
        { "passage_segment_id": "8a", "text": "天に昇って、", "phonetic": "ten ni nobotte," }
      ]
    },
    {
      "passage_id": 9,
      "segments": [
        { "passage_segment_id": "9a", "text": "全能の父である神の右に座り、", "phonetic": "zen'nō no chichi de aru Kami no migi ni zawari," }
      ]
    },
    {
      "passage_id": 10,
      "segments": [
        { "passage_segment_id": "10a", "text": "そこから生者と死者を裁くために来られます。", "phonetic": "soko kara seisha to shisha o sabaku tame ni koraremasu." }
      ]
