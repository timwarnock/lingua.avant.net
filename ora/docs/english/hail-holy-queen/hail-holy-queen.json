        { "passage_segment_id": "1e", "text": "and our hope.", "phonetic": "and our hope." }
      ]
    },
    {
      "passage_id": 2,
      "segments": [
        { "passage_segment_id": "2a", "text": "To thee do we cry,", "phonetic": "To thee do we cry," },
        { "passage_segment_id": "2b", "text": "poor banished children of Eve.", "phonetic": "poor banished children of Eve." }
      ]
    },
    {
      "passage_id": 3,
      "segments": [
        { "passage_segment_id": "3a", "text": "To thee do we send up our sighs,", "phonetic": "To thee do we send up our sighs," },
