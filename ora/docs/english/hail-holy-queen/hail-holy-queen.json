    {
      "passage_id": 1,
      "segments": [
        { "passage_segment_id": "1a", "text": "Hail, Holy Queen,", "phonetic": "Hail, Holy Queen," },
        { "passage_segment_id": "1b", "text": "Mother of mercy,", "phonetic": "Mother of mercy," },
        { "passage_segment_id": "1c", "text": "our life,", "phonetic": "our life," },
