        { "passage_segment_id": "1a", "text": "天におられる", "phonetic": "Ten ni orareru" },
        { "passage_segment_id": "1b", "text": "わたしたちの父よ、", "phonetic": "watashitachi no chichi yo," },
        { "passage_segment_id": "1c", "text": "み名が聖とされますように。", "phonetic": "mina ga sei to saremasu yō ni." }
