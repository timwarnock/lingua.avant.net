      ]
    },
    {
      "passage_id": 3,
      "segments": [
        { "passage_segment_id": "3a", "text": "求祢把眾人的靈魂，", "phonetic": "qiú nǐ bǎ zhòng rén de líng hún," }
      ]
    },
    {
      "passage_id": 4,
      "segments": [
        { "passage_segment_id": "4a", "text": "特別是那些最需要祢憐憫的靈魂，領到天國裏去。", "phonetic": "tè bié shì nà xiē zuì xū yào nǐ lián mǐn de líng hún, lǐng dào tiān guó lǐ qù." }
      ]
    },
    {
      "passage_id": 5,
      "segments": [
        { "passage_segment_id": "5a", "text": "阿們。", "phonetic": "Ā men." }
