      "segments": [
        { "passage_segment_id": "1a", "text": "我的耶穌，", "phonetic": "Wǒ de Yē sū," },
        { "passage_segment_id": "1b", "text": "請寬恕我們的罪過，", "phonetic": "qǐng kuān shù wǒ men de zuì guò," }
      ]
    },
    {
      "passage_id": 2,
      "segments": [
